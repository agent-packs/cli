#!/usr/bin/env python3
import argparse
import json
import os
import shutil
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]
REGISTRY = Path(os.environ.get("AGENT_PACKS_REGISTRY", ROOT / "registry" / "packs"))
DEFAULT_TARGET = Path(os.environ.get("AGENT_PACKS_HOME", ".agent-packs"))
AGENT_SKILL_TARGETS = {
    "claude": ".claude/skills",
    "codex": ".codex/skills",
    "generic": "skills",
}


def load_packs():
    packs = []
    for path in sorted(REGISTRY.glob("*.json")):
        with path.open("r", encoding="utf-8") as handle:
            pack = json.load(handle)
        pack["_path"] = str(path)
        packs.append(pack)
    return packs


def find_pack(pack_id):
    for pack in load_packs():
        if pack["id"] == pack_id:
            return pack
    return None


def public_pack(pack):
    return {key: value for key, value in pack.items() if not key.startswith("_")}


def slugify(value):
    slug = []
    last_was_dash = False
    for char in value.lower():
        if char.isalnum():
            slug.append(char)
            last_was_dash = False
        elif not last_was_dash:
            slug.append("-")
            last_was_dash = True
    return "".join(slug).strip("-") or "capability"


def is_local_source(source):
    return not source.startswith(("http://", "https://", "git@", "ssh://"))


def select_capabilities(pack, only):
    capabilities = pack.get("capabilities", [])
    if only == "all":
        return capabilities
    if only == "skills":
        return [capability for capability in capabilities if capability.get("type") == "skill"]
    if only == "plugins":
        return [capability for capability in capabilities if capability.get("type") == "plugin"]
    return capabilities


def skill_target_root(target, agent):
    return target / AGENT_SKILL_TARGETS.get(agent, AGENT_SKILL_TARGETS["generic"])


def plan_capability(capability, target, agent):
    capability_type = capability.get("type")
    if capability_type == "skill":
        destination = skill_target_root(target, agent) / slugify(capability["name"])
        source = capability.get("source", "")
        entry = capability.get("entry", "SKILL.md")
        local = is_local_source(source)
        return {
            "type": "skill",
            "name": capability["name"],
            "action": "copy" if local else "fetch-copy",
            "source": source,
            "entry": entry,
            "destination": str(destination),
            "status": "planned",
        }

    if capability_type == "plugin":
        install = capability.get("install", {})
        return {
            "type": "plugin",
            "name": capability["name"],
            "action": "native-install",
            "format": capability.get("format"),
            "source": capability.get("source"),
            "command": install.get("command"),
            "method": install.get("method"),
            "package": install.get("package"),
            "marketplace": install.get("marketplace"),
            "status": "planned",
        }

    return {
        "type": capability_type,
        "name": capability.get("name", "unnamed capability"),
        "action": "record",
        "source": capability.get("source"),
        "status": "planned",
    }


def build_install_plan(pack, target, agent, only):
    return {
        "pack": pack["id"],
        "version": pack["version"],
        "agent": agent,
        "target": str(target),
        "capabilities": [
            plan_capability(capability, target, agent)
            for capability in select_capabilities(pack, only)
        ],
    }


def print_plan(plan):
    print(f"Pack: {plan['pack']}")
    print(f"Agent: {plan['agent']}")
    print(f"Target: {plan['target']}")
    print()
    if not plan["capabilities"]:
        print("No matching capabilities.")
        return
    for item in plan["capabilities"]:
        print(f"- {item['type']}: {item['name']}")
        print(f"  action: {item['action']}")
        if item.get("destination"):
            print(f"  destination: {item['destination']}")
        if item.get("command"):
            print(f"  command: {item['command']}")
        if item.get("source"):
            print(f"  source: {item['source']}")


def install_skill(item):
    source = Path(item["source"]).expanduser().resolve()
    destination = Path(item["destination"]).expanduser().resolve()
    entry = item.get("entry", "SKILL.md")

    if not source.exists():
        item["status"] = "pending"
        item["reason"] = "remote or missing skill source; fetch support is not implemented yet"
        return item

    entry_path = source / entry if source.is_dir() else source
    if not entry_path.exists():
        item["status"] = "failed"
        item["reason"] = f"skill entry not found: {entry}"
        return item

    destination.parent.mkdir(parents=True, exist_ok=True)
    if destination.exists():
        shutil.rmtree(destination)
    if source.is_dir():
        shutil.copytree(source, destination)
    else:
        destination.mkdir(parents=True, exist_ok=True)
        shutil.copy2(source, destination / entry_path.name)
    item["status"] = "installed"
    return item


def install_plugin(item, execute_plugins):
    command = item.get("command")
    if not execute_plugins:
        item["status"] = "pending"
        item["reason"] = "plugin command execution requires --execute-plugins"
        return item
    if not command:
        item["status"] = "pending"
        item["reason"] = "plugin install command is not specified"
        return item

    completed = subprocess.run(command, shell=True, text=True, capture_output=True)
    item["exit_code"] = completed.returncode
    item["stdout"] = completed.stdout.strip()
    item["stderr"] = completed.stderr.strip()
    item["status"] = "installed" if completed.returncode == 0 else "failed"
    return item


def execute_plan(plan, execute_plugins):
    results = []
    for item in plan["capabilities"]:
        if item["type"] == "skill":
            results.append(install_skill(item))
        elif item["type"] == "plugin":
            results.append(install_plugin(item, execute_plugins))
        else:
            item["status"] = "recorded"
            results.append(item)
    plan["capabilities"] = results
    return plan


def write_receipt(target, pack, plan):
    receipts_dir = target / "receipts"
    receipts_dir.mkdir(parents=True, exist_ok=True)
    receipt = {
        "installed_at": datetime.now(timezone.utc).isoformat(),
        "pack": public_pack(pack),
        "plan": plan,
    }
    receipt_path = receipts_dir / f"{pack['id']}.json"
    with receipt_path.open("w", encoding="utf-8") as handle:
        json.dump(receipt, handle, indent=2)
        handle.write("\n")
    return receipt_path


def search(args):
    query = " ".join(args.query).lower()
    packs = load_packs()
    if query:
        packs = [
            pack
            for pack in packs
            if query in pack["id"].lower()
            or query in pack["name"].lower()
            or query in pack["description"].lower()
            or any(query in tag.lower() for tag in pack.get("tags", []))
        ]

    if not packs:
        print("No packs found.")
        return 1

    for pack in packs:
        tags = ", ".join(pack.get("tags", []))
        print(f"{pack['id']}	{pack['name']}	{tags}")
    return 0


def show(args):
    pack = find_pack(args.pack_id)
    if not pack:
        print(f"Pack not found: {args.pack_id}", file=sys.stderr)
        return 1

    print(f"{pack['name']} ({pack['id']})")
    print(pack["description"])
    print()
    print(f"Version: {pack['version']}")
    print(f"License: {pack.get('license', 'unknown')}")
    print(f"Tags: {', '.join(pack.get('tags', []))}")
    print()
    print("Capabilities:")
    for capability in pack.get("capabilities", []):
        detail = capability.get("format", capability.get("source", ""))
        print(f"- {capability['type']}: {capability['name']} {detail}".rstrip())
    return 0


def install(args):
    pack = find_pack(args.pack_id)
    if not pack:
        print(f"Pack not found: {args.pack_id}", file=sys.stderr)
        return 1

    target = Path(args.target).expanduser().resolve()
    plan = build_install_plan(pack, target, args.agent, args.only)

    if args.dry_run:
        print_plan(plan)
        return 0

    target.mkdir(parents=True, exist_ok=True)
    pack_dir = target / "packs" / pack["id"]
    pack_dir.mkdir(parents=True, exist_ok=True)

    manifest_path = pack_dir / "agent-pack.json"
    with manifest_path.open("w", encoding="utf-8") as handle:
        json.dump(public_pack(pack), handle, indent=2)
        handle.write("\n")

    source_path = Path(pack["_path"]).resolve()
    shutil.copy2(source_path, pack_dir / "source-registry-entry.json")

    result = execute_plan(plan, args.execute_plugins)
    receipt_path = write_receipt(target, pack, result)
    print_plan(result)
    print()
    print(f"Receipt: {receipt_path}")

    failed = [item for item in result["capabilities"] if item.get("status") == "failed"]
    return 1 if failed else 0


def main():
    parser = argparse.ArgumentParser(prog="agent-packs")
    subcommands = parser.add_subparsers(dest="command", required=True)

    search_parser = subcommands.add_parser("search", help="Search available packs")
    search_parser.add_argument("query", nargs="*")
    search_parser.set_defaults(func=search)

    show_parser = subcommands.add_parser("show", help="Show pack details")
    show_parser.add_argument("pack_id")
    show_parser.set_defaults(func=show)

    install_parser = subcommands.add_parser("install", help="Install a pack")
    install_parser.add_argument("pack_id")
    install_parser.add_argument("--target", default=str(DEFAULT_TARGET))
    install_parser.add_argument("--agent", choices=sorted(AGENT_SKILL_TARGETS), default="generic")
    install_parser.add_argument("--only", choices=["all", "skills", "plugins"], default="all")
    install_parser.add_argument("--dry-run", action="store_true")
    install_parser.add_argument("--execute-plugins", action="store_true")
    install_parser.set_defaults(func=install)

    args = parser.parse_args()
    raise SystemExit(args.func(args))


if __name__ == "__main__":
    main()
